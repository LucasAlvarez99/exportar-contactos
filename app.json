{
  "expo": {
    "name": "Exportar Contactos",
    "slug": "exportar-contactos",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "android": {
      "permissions": ["android.permission.READ_CONTACTS"]
    },
    "ios": {
      "infoPlist": {
        "NSContactsUsageDescription": "Necesitamos acceso a tus contactos para exportarlos."
      }
    },
    "plugins": ["expo-contacts"]
  }
}
